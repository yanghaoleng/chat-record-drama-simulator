{
  "buildCommand": "npm run build:ququ",
  "outputDirectory": "dist/ququ",
  "rewrites": [
    {
      "source": "/api/story/continue",
      "destination": "/api/story/continue"
    },
    {
      "source": "/api/settings/deepseek",
      "destination": "/api/settings/deepseek"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/health"
    },
    {
      "source": "/ding",
      "destination": "/ding/index.html"
    },
    {
      "source": "/ding/(.*)",
      "destination": "/ding/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
