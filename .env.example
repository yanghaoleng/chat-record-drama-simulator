# Never commit real secrets. Paste local values into .env.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional browser-direct mode. Any VITE_* value is embedded into the browser bundle.
# Do not put a private API key here unless you accept that visitors can see and reuse it.
VITE_DEEPSEEK_API_KEY=
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com
VITE_DEEPSEEK_MODEL=deepseek-chat
VITE_GITHUB_REPO_URL=https://github.com/yanghaoleng/FakeChat

# Required for voice generation/rendering. The API only uses the VoxCPM-compatible worker.
# It no longer falls back to macOS `say` or synthetic tones.
VOXCPM_WORKER_URL=

API_PORT=8787
PUBLIC_API_ORIGIN=http://127.0.0.1:8787
